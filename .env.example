# Runtime
NODE_ENV="development"
PORT="4000"

# PostgreSQL
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/ivory_store?schema=public"

# Authentication. AUTH_SECRET dari konfigurasi lama dipetakan ke JWT_SECRET.
# Ganti dengan secret acak minimal 32 karakter sebelum production.
JWT_SECRET="development-only-secret-change-me"

# Application origins
FRONTEND_URL="http://localhost:3000,https://onlineshop-sigma.vercel.app"
BACKEND_PUBLIC_URL="http://localhost:4000"
COOKIE_DOMAIN=""
SWAGGER_ENABLED="true"

# Transactional email: pilih "gmail" atau "resend".
EMAIL_PROVIDER="gmail"

# Gmail SMTP. Aktifkan 2-Step Verification lalu gunakan App Password, bukan password akun.
GMAIL_USER=""
GMAIL_APP_PASSWORD=""
GMAIL_FROM_NAME="IVORY"

# Resend. Dipakai hanya saat EMAIL_PROVIDER="resend".
RESEND_API_KEY=""
EMAIL_FROM="IVORY <noreply@mail.example.com>"

# Midtrans payment. false = Sandbox, true = Production.
# Server Key harus berasal dari environment Midtrans yang sama.
MIDTRANS_SERVER_KEY=""
MIDTRANS_IS_PRODUCTION="false"
MIDTRANS_PAYMENT_EXPIRY_MINUTES="60"

# Shipping. Base URL sama; API key menentukan Testing atau Production.
BITESHIP_IS_PRODUCTION="false"
BITESHIP_API_KEY_TEST=""
BITESHIP_API_KEY_LIVE=""
BITESHIP_BASE_URL="https://api.biteship.com/v1"
BITESHIP_WEBHOOK_SECRET=""
BITESHIP_SHIPPER_NAME="IVORY"
BITESHIP_SHIPPER_PHONE=""
BITESHIP_SHIPPER_EMAIL=""
BITESHIP_SHIPPER_ORGANIZATION="IVORY"
BITESHIP_ORIGIN_CONTACT_NAME="IVORY Warehouse"
BITESHIP_ORIGIN_CONTACT_PHONE=""
BITESHIP_ORIGIN_CONTACT_EMAIL=""
BITESHIP_ORIGIN_ADDRESS=""
BITESHIP_ORIGIN_NOTE=""
BITESHIP_ORIGIN_POSTAL_CODE="12950"

# Image storage
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Development seed credentials
SEED_ADMIN_EMAIL="admin@example.test"
SEED_ADMIN_PASSWORD=""
SEED_CUSTOMER_EMAIL="customer@example.test"
SEED_CUSTOMER_PASSWORD=""
