# Runtime
NODE_ENV="development"
PORT="4000"

# PostgreSQL
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/ivory_store?schema=public"

# Authentication. AUTH_SECRET dari konfigurasi lama dipetakan ke JWT_SECRET.
# Ganti dengan secret acak minimal 32 karakter sebelum production.
JWT_SECRET="development-only-secret-change-me"

# Application origins
FRONTEND_URL="http://localhost:3000"
BACKEND_PUBLIC_URL="http://localhost:4000"
SWAGGER_ENABLED="true"

# Email
RESEND_API_KEY=""
EMAIL_FROM="IVORY <noreply@example.com>"

# Payment
MIDTRANS_SERVER_KEY=""
MIDTRANS_IS_PRODUCTION="false"

# Shipping
BITESHIP_API_KEY=""
BITESHIP_BASE_URL="https://api.biteship.com/v1"
BITESHIP_ORIGIN_POSTAL_CODE="12950"

# Image storage
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Development seed credentials
SEED_ADMIN_EMAIL="admin@example.test"
SEED_ADMIN_PASSWORD=""
SEED_CUSTOMER_EMAIL="customer@example.test"
SEED_CUSTOMER_PASSWORD=""
